# ==============================================================================
# InternOps Environment Configuration Template
# Copy this file to .env in your backend directory and configure placeholders.
# ==============================================================================

# ==========================================
# REQUIRED ENVIRONMENT VARIABLES
# ==========================================

# Current application environment (development | production | test)
NODE_ENV=development

# Core API JSON Web Token sign/verify secret key
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long

# Database connection URL (PostgreSQL)
# Must start with postgres:// or postgresql://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internops

# ==========================================
# PRODUCTION-REQUIRED VARIABLES
# ==========================================

# High-entropy refresh token secret.
# Required when NODE_ENV=production. Must NOT be the same as JWT_SECRET.
JWT_REFRESH_SECRET=your-separate-high-entropy-refresh-token-secret-key


# ==========================================
# OPTIONAL ENVIRONMENT VARIABLES
# ==========================================

# PORT: The port backend listens on (defaults to 5000)
PORT=5000

# REDIS: connection URL for caching/rate-limiting
REDIS_URL=redis://localhost:6379

# UPSTASH REDIS: REST connection details
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# GOOGLE AUTH: OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PHONE OTP (FAST2SMS)
FAST2SMS_API_KEY=your-fast2sms-api-key

# AI MODULE: API Timeout and Provider Keys
FASTAPI_URL=http://localhost:8000/api/chat
AI_TIMEOUT=25000
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
HUGGINGFACE_TOKEN=your-hf-token

# AI CACHE CONFIG
AI_CACHE_MAX_ENTRIES=5000
AI_CHAT_RATE_LIMIT_PER_MIN=10
AI_MAX_RESPONSE_BYTES=2097152
AI_CHAT_DAILY_LIMIT=100

# EMAIL (SMTP / SENDGRID / MAILGUN)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
EMAIL_API_KEY=your-sendgrid-or-mailgun-api-key
EMAIL_FROM=noreply@internops.com
EMAIL_PROVIDER=smtp
EMAIL_RETRY_MAX=3
EMAIL_RATE_LIMIT=5
EMAIL_RATE_WINDOW=60000
EMAIL_BOUNCE_CHECK=true

# APP REFERENCE URL
APP_URL=http://localhost:5173

# SEED ADMIN CREDENTIALS (used for migrations and seeding)
SEED_ADMIN_EMAIL=admin@internops.com
SEED_ADMIN_PASSWORD=Admin@123
